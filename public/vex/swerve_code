// ============================================================================\n//  VEX SWERVE DRIVE CONTROLLER\n// ============================================================================\n//\n//  This program implements swerve (crab) drive for a 4-module VEX robot.\n//  Each module has two motors: one for driving and one for steering.\n//  Optical shaft encoders on 3-wire ports track the absolute steering angle.\n//\n//  HOW IT WORKS:\n//    - The joystick inputs (strafe X, strafe Y, rotation) are converted into\n//      per-wheel speed and angle targets using inverse kinematics.\n//    - Each module optimizes its path: if a target angle is more than 90°\n//      away, the wheel reverses direction instead of taking the long way around.\n//    - Wheel speeds are normalized so no wheel exceeds maxSpeed.\n//\n//  COORDINATE SYSTEM:\n//    - X = left/right (positive = right)\n//    - Y = forward/back (positive = forward)\n//    - Rotation = positive = counter-clockwise\n//\n//  CONTROLS (default VEX controller layout):\n//\n//    LEFT STICK                     RIGHT STICK\n//    ┌─────────┐                    ┌─────────┐\n//    │    ↑    │                    │    ↑    │\n//    │  Axis3  │                    │  Axis2  │  Push forward = drive forward\n//    │ ← Axis4→│  Turn left/right   │ ← Axis1→│  Strafe left/right\n//    │    ↓    │                    │    ↓    │  Pull back = drive backward\n//    └─────────┘                    └─────────┘\n//\n//    Right Stick Y (Axis 2) = Forward / backward translation\n//    Right Stick X (Axis 1) = Left / right strafing\n//    Left  Stick X (Axis 4) = Rotation (spin in place or while moving)\n//    Left  Stick Y (Axis 3) = Not used\n//\n//    All sticks output -100 to +100 (percent). Values inside the deadband\n//    (default ±3%) are zeroed to prevent drift when sticks aren't touched.\n//\n//  HOW TO CHANGE CONTROLS:\n//    The stick assignments are in control_task(). To swap sticks, change\n//    which Axis is read into x, y, and r. For example, to use the left\n//    stick for driving and right stick for rotation:\n//\n//      double x = Controller1.Axis4.position(percent);  // left X  -> strafe\n//      double y = Controller1.Axis3.position(percent);  // left Y  -> forward\n//      double r = Controller1.Axis1.position(percent);  // right X -> rotate\n//\n//    VEX axis reference:\n//      Axis1 = Right stick horizontal\n//      Axis2 = Right stick vertical\n//      Axis3 = Left stick vertical\n//      Axis4 = Left stick horizontal\n//\n// ============================================================================\n\n#include <stdio.h>\n#include <stdlib.h>\n#include <stdbool.h>\n#include <math.h>\n#include <string.h>\n#include <cmath>\n#include <algorithm>\n\n#include \"vex.h\"\n\nusing namespace vex;\n\n// ============================================================================\n//  PORT CONFIGURATION\n// ============================================================================\n//\n//  Module layout (top-down view of robot):\n//\n//      FRONT\n//    [0]   [3]       Module 0 = Front-Left,  Module 3 = Front-Right\n//    [1]   [2]       Module 1 = Back-Left,   Module 2 = Back-Right\n//      BACK\n//\n//  To change a port: update the number in the array below.\n//  Use PORT1 through PORT21 for smart ports (motors).\n//  Encoder triport is set separately below.\n//\n//  DRIVE MOTORS - these spin the wheels (provide forward/backward power)\n//  Order: { Front-Left, Back-Left, Back-Right, Front-Right }\nint drivePorts[] = {PORT10, PORT1, PORT11, PORT20};\n\n//  STEERING MOTORS - these rotate the modules (change wheel direction)\n//  Order: { Front-Left, Back-Left, Back-Right, Front-Right }\nint positionPorts[] = {PORT9, PORT2, PORT12, PORT19};\n\n//  ENCODER 3-WIRE PORT\n//  The triport expander that all four encoders plug into.\n//  Each encoder uses two adjacent 3-wire ports (A+B, C+D, E+F, G+H).\n//  Change PORT8 if your triport expander is in a different smart port.\nconst int encoderTriportPort = PORT8;\n\n//  MOTOR GEAR CARTRIDGE\n//  Change this to match the cartridge installed in your motors:\n//    ratio36_1  = 100 RPM (red cartridge, high torque)\n//    ratio18_1  = 200 RPM (green cartridge, default)\n//    ratio6_1   = 600 RPM (blue cartridge, high speed)\nconst gearSetting driveGearRatio    = ratio36_1;\nconst gearSetting steeringGearRatio = ratio36_1;\n\n//  MOTOR DIRECTION\n//  Set to true to reverse a motor's default direction.\n//  Useful if a motor is physically mounted backwards.\nconst bool driveReversed    = true;\nconst bool steeringReversed = true;\n\n//  MODULE ENABLE/DISABLE (for testing)\n//  Set an entry to false to completely disable that module.\n//  Useful when building/debugging one module at a time.\n//  Order: { Front-Left, Back-Left, Back-Right, Front-Right }\nbool moduleEnabled[4] = {true, true, true, true};\n\n// ============================================================================\n//  ROBOT DIMENSIONS\n// ============================================================================\n//\n//  These define the physical geometry of your robot and directly affect how\n//  rotation commands are translated into per-wheel angles.\n//\n//  Measure center-to-center between wheels in consistent units (mm recommended).\n//\n//  wheelBase  = distance between front and rear axles\n//  trackWidth = distance between left and right wheels\n//\n//  Example: if your front and rear wheels are 300mm apart and your left and\n//  right wheels are 250mm apart, set wheelBase=300, trackWidth=250.\n\nconst double wheelBase  = 100.0;  // TODO: measure your robot and update\nconst double trackWidth = 100.0;  // TODO: measure your robot and update\n\n// ============================================================================\n//  STEERING ENCODER GEAR RATIO\n// ============================================================================\n//\n//  If there is a gear reduction between the encoder and the module rotation,\n//  set this ratio so the encoder reading is converted to actual module angle.\n//\n//  Formula: actual_angle = encoder_reading * (driven_teeth / driving_teeth)\n//\n//  Example: if the encoder gear has 5 teeth and the module gear has 7 teeth,\n//  the ratio is 5.0 / 7.0.\n//  Set to 1.0 if the encoder is directly coupled (no gearing).\n\nconst double encoderGearRatio = 5.0 / 7.0;\n\n// ============================================================================\n//  TUNING PARAMETERS\n// ============================================================================\n\n//  Maximum wheel speed in percent (0-100). Lowering this limits top speed\n//  but can make the robot easier to control.\ndouble maxSpeed = 100.0;\n\n//  Joystick deadband in percent. Any joystick input below this value is\n//  treated as zero. Increase if the robot drifts when sticks are released.\nconst double joystickDeadband = 3.0;\n\n// ============================================================================\n//  INTERNAL CONSTANTS (derived from dimensions above - do not edit)\n// ============================================================================\n\ndouble hypt2(double a, double b) { return sqrt(a * a + b * b); }\n\nconst double halfWheelBase   = wheelBase / 2.0;\nconst double halfTrackWidth  = trackWidth / 2.0;\nconst double effectiveRadius = hypt2(halfWheelBase, halfTrackWidth);\n\nconstexpr double rad_to_deg = 180.0 / M_PI;\n\n//  Unit vectors from robot center to each wheel, normalized by the effective\n//  radius. These encode the geometry for the inverse kinematics.\n//  [i][0] = forward/back component, [i][1] = left/right component\nconst double wheelVectors[4][2] = {\n  {-halfWheelBase / effectiveRadius,  halfTrackWidth / effectiveRadius},   // Front-Left\n  {-halfWheelBase / effectiveRadius, -halfTrackWidth / effectiveRadius},   // Back-Left\n  { halfWheelBase / effectiveRadius, -halfTrackWidth / effectiveRadius},   // Back-Right\n  { halfWheelBase / effectiveRadius,  halfTrackWidth / effectiveRadius}    // Front-Right\n};\n\n// ============================================================================\n//  GLOBAL STATE\n// ============================================================================\n\nbrain      Brain;\ncontroller Controller1 = controller(primary);\n\nmotor* motorsDrive[4];     // Drive motor pointers (one per module)\nmotor* motorsPosition[4];  // Steering motor pointers (one per module)\n\n//  Current known steering angle of each module (degrees, from encoder)\ndouble wheelPositions[4] = {0, 0, 0, 0};\n\n//  Target delta-angle and speed for each module (set by calculateSwerve)\ndouble targetAngles[4] = {0, 0, 0, 0};\ndouble targetSpeeds[4] = {0, 0, 0, 0};\n\n//  Encoders (initialized in main)\ntriport encoderTriport = triport(encoderTriportPort);\nencoder encoders[4] = {\n  encoder(encoderTriport.A),  // Module 0: uses 3-wire ports A+B\n  encoder(encoderTriport.C),  // Module 1: uses 3-wire ports C+D\n  encoder(encoderTriport.E),  // Module 2: uses 3-wire ports E+F\n  encoder(encoderTriport.G)   // Module 3: uses 3-wire ports G+H\n};\n\n// ============================================================================\n//  SWERVE INVERSE KINEMATICS\n// ============================================================================\n//\n//  Takes joystick inputs and computes the target angle and speed for each\n//  swerve module.\n//\n//  Parameters:\n//    vx - strafe velocity (positive = right)\n//    vy - forward velocity (positive = forward)\n//    w  - rotational velocity (positive = counter-clockwise)\n//\n//  Outputs are stored in targetSpeeds[] and targetAngles[].\n\nvoid calculateSwerve(double vx, double vy, double w) {\n  double maxCalculatedSpeed = 0.0;\n\n  for (int i = 0; i < 4; ++i) {\n    // Compute the rotational component for this wheel.\n    // The rotation vector is perpendicular to the line from center to wheel.\n    double rx = wheelVectors[i][1] * w;\n    double ry = -wheelVectors[i][0] * w;\n\n    // Combine translation and rotation to get the final velocity vector.\n    double fx = rx + vx;\n    double fy = ry + vy;\n\n    // Convert to polar (speed + angle).\n    double speed = hypot(fy, fx);\n    double angle = atan2(fy, fx) * rad_to_deg;\n\n    // Compute the shortest path to the target angle.\n    // Result is in the range (-180, 180].\n    double delta = fmod(angle - wheelPositions[i] + 180.0, 360.0) - 180.0;\n\n    // Optimization: if the target is more than 90° away, reverse the wheel\n    // and go the shorter direction. This prevents modules from spinning\n    // 270° when they could just reverse and turn 90°.\n    if (fabs(delta) > 90.0) {\n      delta += (delta > 0) ? -180.0 : 180.0;\n      speed = -speed;\n    }\n\n    targetSpeeds[i] = speed;\n    targetAngles[i] = delta;\n\n    maxCalculatedSpeed = std::max(maxCalculatedSpeed, fabs(speed));\n  }\n\n  // Normalize speeds so no wheel exceeds maxSpeed.\n  // All wheels are scaled equally to preserve the motion vector.\n  if (maxCalculatedSpeed > maxSpeed) {\n    double scale = maxSpeed / maxCalculatedSpeed;\n    for (int i = 0; i < 4; ++i) {\n      targetSpeeds[i] *= scale;\n    }\n  }\n}\n\n// ============================================================================\n//  CONTROL TASK (runs on its own thread)\n// ============================================================================\n//\n//  Reads joystick inputs, applies deadband, and feeds them into the swerve\n//  kinematics calculator. Runs every 20ms (~50Hz).\n\nint control_task() {\n  while (true) {\n    double x = Controller1.Axis1.position(percent);  // Right stick X (strafe)\n    double y = Controller1.Axis2.position(percent);  // Right stick Y (forward)\n    double r = Controller1.Axis4.position(percent);  // Left stick X  (rotate)\n\n    // Zero out inputs inside the deadband to prevent drift.\n    if (fabs(x) < joystickDeadband) x = 0;\n    if (fabs(y) < joystickDeadband) y = 0;\n    if (fabs(r) < joystickDeadband) r = 0;\n\n    calculateSwerve(x, y, r);\n    wait(20, msec);\n  }\n  return 0;\n}\n\n// ============================================================================\n//  MOTOR TASK (runs on its own thread)\n// ============================================================================\n//\n//  Reads encoder positions, then commands each module's steering and drive\n//  motors based on the latest targets from calculateSwerve().\n//\n//  NOTE: spinFor() is used here for steering. This is a known limitation —\n//  for smoother control, consider replacing with a PID loop that uses spin()\n//  with a proportional velocity toward an absolute target angle. spinFor()\n//  can behave erratically when called repeatedly in a loop since it's\n//  designed for one-shot relative movements.\n\nint motor_task() {\n  while (true) {\n    for (int i = 0; i < 4; i++) {\n      if (!moduleEnabled[i]) {\n        motorsDrive[i]->stop();\n        continue;\n      }\n\n      // Read the current steering angle from the encoder.\n      // The negative sign accounts for encoder mounting direction — flip\n      // if your modules steer in the wrong direction.\n      double currentAngle = -encoders[i].position(degrees) * encoderGearRatio;\n      wheelPositions[i] = currentAngle;\n\n      // Wrap the delta angle to (-180, 180].\n      double delta = fmod(targetAngles[i] + 180.0, 360.0) - 180.0;\n\n      // Command the steering motor to rotate by the delta.\n      // false = non-blocking so all modules move simultaneously.\n      motorsPosition[i]->spinFor(delta, degrees, false);\n\n      // Command the drive motor.\n      motorsDrive[i]->spin(forward);\n      motorsDrive[i]->setVelocity(targetSpeeds[i], percent);\n    }\n    wait(20, msec);\n  }\n  return 0;\n}\n\n// ============================================================================\n//  MAIN - initialization and startup\n// ============================================================================\n\nint main() {\n  // Initialize motors for each enabled module.\n  for (int i = 0; i < 4; i++) {\n    if (!moduleEnabled[i]) {\n      motorsDrive[i]    = nullptr;\n      motorsPosition[i] = nullptr;\n      continue;\n    }\n\n    motorsDrive[i]    = new motor(drivePorts[i], driveGearRatio, driveReversed);\n    motorsPosition[i] = new motor(positionPorts[i], steeringGearRatio, steeringReversed);\n\n    // Hold mode makes the steering motor actively resist being pushed\n    // off its target angle. This keeps the modules from rotating freely.\n    motorsPosition[i]->setStopping(hold);\n  }\n\n  // Launch the control and motor loops as separate threads.\n  task controlLoop(control_task);\n  task motorLoop(motor_task);\n\n  // Keep main alive. The real work happens in the tasks above.\n  while (true) {\n    wait(100, msec);\n  }\n}