#define SCREEN_W 480
#define SCREEN_H 230

uint32_t screenBuffer[SCREEN_W * SCREEN_H];

#define PI 3.14159265f
#define DEG2RAD (PI / 180.0f)
float fabs_(float x){return x<0?-x:x;}
float fmin_(float a,float b){return a<b?a:b;}
float fmax_(float a,float b){return a>b?a:b;}
float fclamp(float v,float lo,float hi){return fmax_(lo,fmin_(hi,v));}

uint32_t rgba(int r,int g,int b,int a=255){
    return ((uint32_t)a<<24)|((uint32_t)r<<16)|((uint32_t)g<<8)|(uint32_t)b;
}

// ---------- Drawing ----------
void clearBuffer(uint32_t c){for(int i=0;i<SCREEN_W*SCREEN_H;i++)screenBuffer[i]=c;}
void setPixel(int x,int y,uint32_t c){if(x>=0&&x<SCREEN_W&&y>=0&&y<SCREEN_H)screenBuffer[y*SCREEN_W+x]=c;}
void blendPixel(int x,int y,uint32_t c,int a){
    if(x<0||x>=SCREEN_W||y<0||y>=SCREEN_H||a<=0)return;
    if(a>=255){screenBuffer[y*SCREEN_W+x]=c;return;}
    uint32_t d=screenBuffer[y*SCREEN_W+x];
    screenBuffer[y*SCREEN_W+x]=rgba(
        ((d>>16)&0xFF)+(((int)((c>>16)&0xFF)-(int)((d>>16)&0xFF))*a>>8),
        ((d>>8)&0xFF)+(((int)((c>>8)&0xFF)-(int)((d>>8)&0xFF))*a>>8),
        (d&0xFF)+(((int)(c&0xFF)-(int)(d&0xFF))*a>>8));
}
void fillRect(int x1,int y1,int x2,int y2,uint32_t c){
    for(int y=y1;y<=y2;y++)for(int x=x1;x<=x2;x++)setPixel(x,y,c);
}
void fillCircle(int cx,int cy,int r,uint32_t c){
    int r2=r*r;for(int y=-r;y<=r;y++)for(int x=-r;x<=r;x++)if(x*x+y*y<=r2)setPixel(cx+x,cy+y,c);
}
void drawRing(int cx,int cy,int r,int t,uint32_t c){
    int o2=r*r,i2=(r-t)*(r-t);
    for(int y=-r;y<=r;y++)for(int x=-r;x<=r;x++){int d=x*x+y*y;if(d<=o2&&d>=i2)setPixel(cx+x,cy+y,c);}
}

// Antialiased filled circle
void fillCircleAA(int cx,int cy,float r,uint32_t c){
    int ir=(int)(r+1.5f);
    for(int y=-ir;y<=ir;y++)for(int x=-ir;x<=ir;x++){
        float dist=sqrtf((float)(x*x+y*y));
        if(dist<=r-0.5f) setPixel(cx+x,cy+y,c);
        else if(dist<r+0.5f) blendPixel(cx+x,cy+y,c,(int)((r+0.5f-dist)*255));
    }
}

void fillHexagon(int cx,int cy,int r,uint32_t c){
    for(int py=-r-1;py<=r+1;py++) for(int px=-r-1;px<=r+1;px++){
        float ax=fabs_((float)px), ay=fabs_((float)py);
        float fr=(float)r;
        float s3=0.866f;
        if(ay <= fr*s3 && ay <= -1.732f*ax + fr*1.732f)
            setPixel(cx+px,cy+py,c);
    }
}

void drawHexagonOutline(int cx,int cy,int r,int thick,uint32_t c){
    for(int py=-r-2;py<=r+2;py++) for(int px=-r-2;px<=r+2;px++){
        float ax=fabs_((float)px), ay=fabs_((float)py);
        float fr=(float)r, fri=(float)(r-thick);
        float s3=0.866f;
        bool outer = (ay<=fr*s3 && ay<=-1.732f*ax+fr*1.732f);
        bool inner = (ay<=fri*s3 && ay<=-1.732f*ax+fri*1.732f);
        if(outer && !inner) setPixel(cx+px,cy+py,c);
    }
}

// SDF rect
static float rectSDF(float lx,float ly,float hw,float hh){
    float dx=fabs_(lx)-hw,dy=fabs_(ly)-hh;
    return sqrtf(fmax_(dx,0)*fmax_(dx,0)+fmax_(dy,0)*fmax_(dy,0))+fmin_(fmax_(dx,dy),0.0f);
}
void fillRotatedRect(int cx,int cy,int hw,int hh,float ang,uint32_t c){
    float rad=ang*DEG2RAD,co=cosf(rad),si=sinf(rad);
    float fhw=(float)hw,fhh=(float)hh;int b=hw+hh+2;
    for(int py=-b;py<=b;py++)for(int px=-b;px<=b;px++){
        float lx=px*co+py*si,ly=-px*si+py*co;float d=rectSDF(lx,ly,fhw,fhh);
        if(d<1){if(d<=0)setPixel(cx+px,cy+py,c);else blendPixel(cx+px,cy+py,c,(int)((1-d)*255));}
    }
}
void drawRotatedRectOutline(int cx,int cy,int hw,int hh,float ang,int th,uint32_t c){
    float rad=ang*DEG2RAD,co=cosf(rad),si=sinf(rad);
    float fhw=(float)hw,fhh=(float)hh,ihw=(float)(hw-th),ihh=(float)(hh-th);int b=hw+hh+2;
    for(int py=-b;py<=b;py++)for(int px=-b;px<=b;px++){
        float lx=px*co+py*si,ly=-px*si+py*co;
        float oc=1-fmax_(fmin_(rectSDF(lx,ly,fhw,fhh)+.5f,1.f),0.f);
        float ic=1-fmax_(fmin_(rectSDF(lx,ly,ihw,ihh)+.5f,1.f),0.f);
        float cv=oc-ic;if(cv>.01f){int a=(int)(cv*255);
            if(a>=255)setPixel(cx+px,cy+py,c);else blendPixel(cx+px,cy+py,c,a);}
    }
}

