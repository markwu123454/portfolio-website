#define BLUE_BUMP_X 120
#define RED_BUMP_X  360
#define BUMP_HW     2

#define BLUE_HUB_X BLUE_BUMP_X
#define BLUE_HUB_Y (SCREEN_H/2)
#define RED_HUB_X  RED_BUMP_X
#define RED_HUB_Y  (SCREEN_H/2)
#define HUB_HEX_R 18

#define HUB_ZONE_HW 24
#define HUB_ZONE_HH 24

#define TRENCH_WIDTH 22
#define BLUE_TRENCH_X1 (BLUE_BUMP_X - TRENCH_WIDTH - BUMP_HW)
#define BLUE_TRENCH_X2 (BLUE_BUMP_X - BUMP_HW - 1)
#define RED_TRENCH_X1  (RED_BUMP_X + BUMP_HW + 1)
#define RED_TRENCH_X2  (RED_BUMP_X + TRENCH_WIDTH + BUMP_HW)

#define HORIZ_WALL_TOP_Y (BLUE_HUB_Y - HUB_ZONE_HH - 8)
#define HORIZ_WALL_BOT_Y (BLUE_HUB_Y + HUB_ZONE_HH + 8)

#define HUB_GOAL_R 10.0f
#define HUB_RIM_R  20.0f
#define EXIT_SPEED 2.5f

void initWalls(){
    addWR(BLUE_HUB_X, BLUE_HUB_Y, HUB_ZONE_HW, HUB_ZONE_HH);
    addWR(RED_HUB_X, RED_HUB_Y, HUB_ZONE_HW, HUB_ZONE_HH);

    float hCx_b = (BLUE_TRENCH_X1 + BLUE_BUMP_X + BUMP_HW) * 0.5f;
    float hHw_b = (BLUE_BUMP_X + BUMP_HW - BLUE_TRENCH_X1) * 0.5f;
    addWR(hCx_b, HORIZ_WALL_TOP_Y, hHw_b, 4);
    addWR(hCx_b, HORIZ_WALL_BOT_Y, hHw_b, 4);

    float hCx_r = (RED_BUMP_X - BUMP_HW + RED_TRENCH_X2) * 0.5f;
    float hHw_r = (RED_TRENCH_X2 - (RED_BUMP_X - BUMP_HW)) * 0.5f;
    addWR(hCx_r, HORIZ_WALL_TOP_Y, hHw_r, 4);
    addWR(hCx_r, HORIZ_WALL_BOT_Y, hHw_r, 4);
}

void drawField(){
    for(int y=0;y<SCREEN_H;y++){setPixel(SCREEN_W/2,y,rgba(70,70,80));setPixel(SCREEN_W/2+1,y,rgba(70,70,80));}

    for(int y=2;y<SCREEN_H-2;y++){
        for(int x=2;x<40;x++) blendPixel(x,y,rgba(30,30,100),25);
        for(int x=SCREEN_W-40;x<SCREEN_W-2;x++) blendPixel(x,y,rgba(100,30,30),25);
    }

    uint32_t trenchBlue=rgba(30,35,80);
    fillRect(BLUE_TRENCH_X1, 1, BLUE_TRENCH_X2, HORIZ_WALL_TOP_Y-1, trenchBlue);
    fillRect(BLUE_TRENCH_X1, HORIZ_WALL_BOT_Y+1, BLUE_TRENCH_X2, SCREEN_H-2, trenchBlue);

    uint32_t trenchRed=rgba(80,30,30);
    fillRect(RED_TRENCH_X1, 1, RED_TRENCH_X2, HORIZ_WALL_TOP_Y-1, trenchRed);
    fillRect(RED_TRENCH_X1, HORIZ_WALL_BOT_Y+1, RED_TRENCH_X2, SCREEN_H-2, trenchRed);

    uint32_t wallBlueCol=rgba(40,50,130);
    uint32_t wallRedCol=rgba(130,40,40);
    fillRect(BLUE_TRENCH_X1, HORIZ_WALL_TOP_Y-4, BLUE_BUMP_X+BUMP_HW, HORIZ_WALL_TOP_Y+4, wallBlueCol);
    fillRect(BLUE_TRENCH_X1, HORIZ_WALL_BOT_Y-4, BLUE_BUMP_X+BUMP_HW, HORIZ_WALL_BOT_Y+4, wallBlueCol);
    fillRect(RED_BUMP_X-BUMP_HW, HORIZ_WALL_TOP_Y-4, RED_TRENCH_X2, HORIZ_WALL_TOP_Y+4, wallRedCol);
    fillRect(RED_BUMP_X-BUMP_HW, HORIZ_WALL_BOT_Y-4, RED_TRENCH_X2, HORIZ_WALL_BOT_Y+4, wallRedCol);

    uint32_t bumpBlue=rgba(40,50,160);
    uint32_t bumpRed=rgba(160,40,40);
    fillRect(BLUE_BUMP_X-BUMP_HW, 1, BLUE_BUMP_X+BUMP_HW, SCREEN_H-2, bumpBlue);
    fillRect(RED_BUMP_X-BUMP_HW, 1, RED_BUMP_X+BUMP_HW, SCREEN_H-2, bumpRed);

    uint32_t zoneGray=rgba(45,45,55);
    uint32_t zoneBorder=rgba(75,75,85);

    fillRect(BLUE_HUB_X-HUB_ZONE_HW, BLUE_HUB_Y-HUB_ZONE_HH,
             BLUE_HUB_X+HUB_ZONE_HW, BLUE_HUB_Y+HUB_ZONE_HH, zoneGray);
    fillRect(BLUE_HUB_X-HUB_ZONE_HW, BLUE_HUB_Y-HUB_ZONE_HH, BLUE_HUB_X+HUB_ZONE_HW, BLUE_HUB_Y-HUB_ZONE_HH+1, zoneBorder);
    fillRect(BLUE_HUB_X-HUB_ZONE_HW, BLUE_HUB_Y+HUB_ZONE_HH-1, BLUE_HUB_X+HUB_ZONE_HW, BLUE_HUB_Y+HUB_ZONE_HH, zoneBorder);
    fillRect(BLUE_HUB_X-HUB_ZONE_HW, BLUE_HUB_Y-HUB_ZONE_HH, BLUE_HUB_X-HUB_ZONE_HW+1, BLUE_HUB_Y+HUB_ZONE_HH, zoneBorder);
    fillRect(BLUE_HUB_X+HUB_ZONE_HW-1, BLUE_HUB_Y-HUB_ZONE_HH, BLUE_HUB_X+HUB_ZONE_HW, BLUE_HUB_Y+HUB_ZONE_HH, zoneBorder);

    fillHexagon(BLUE_HUB_X,BLUE_HUB_Y,HUB_HEX_R,rgba(40,50,90));
    drawHexagonOutline(BLUE_HUB_X,BLUE_HUB_Y,HUB_HEX_R,3,rgba(60,90,180));
    fillHexagon(BLUE_HUB_X,BLUE_HUB_Y,9,rgba(20,30,60));
    drawHexagonOutline(BLUE_HUB_X,BLUE_HUB_Y,9,2,rgba(80,120,200));
    fillCircle(BLUE_HUB_X,BLUE_HUB_Y,3,rgba(100,160,255));

    fillRect(RED_HUB_X-HUB_ZONE_HW, RED_HUB_Y-HUB_ZONE_HH,
             RED_HUB_X+HUB_ZONE_HW, RED_HUB_Y+HUB_ZONE_HH, zoneGray);
    fillRect(RED_HUB_X-HUB_ZONE_HW, RED_HUB_Y-HUB_ZONE_HH, RED_HUB_X+HUB_ZONE_HW, RED_HUB_Y-HUB_ZONE_HH+1, zoneBorder);
    fillRect(RED_HUB_X-HUB_ZONE_HW, RED_HUB_Y+HUB_ZONE_HH-1, RED_HUB_X+HUB_ZONE_HW, RED_HUB_Y+HUB_ZONE_HH, zoneBorder);
    fillRect(RED_HUB_X-HUB_ZONE_HW, RED_HUB_Y-HUB_ZONE_HH, RED_HUB_X-HUB_ZONE_HW+1, RED_HUB_Y+HUB_ZONE_HH, zoneBorder);
    fillRect(RED_HUB_X+HUB_ZONE_HW-1, RED_HUB_Y-HUB_ZONE_HH, RED_HUB_X+HUB_ZONE_HW, RED_HUB_Y+HUB_ZONE_HH, zoneBorder);

    fillHexagon(RED_HUB_X,RED_HUB_Y,HUB_HEX_R,rgba(90,40,40));
    drawHexagonOutline(RED_HUB_X,RED_HUB_Y,HUB_HEX_R,3,rgba(180,60,60));
    fillHexagon(RED_HUB_X,RED_HUB_Y,9,rgba(60,20,20));
    drawHexagonOutline(RED_HUB_X,RED_HUB_Y,9,2,rgba(200,80,80));
    fillCircle(RED_HUB_X,RED_HUB_Y,3,rgba(255,100,100));

    for(int x=0;x<SCREEN_W;x++){setPixel(x,0,rgba(90,90,90));setPixel(x,SCREEN_H-1,rgba(90,90,90));}
    for(int y=0;y<SCREEN_H;y++){setPixel(0,y,rgba(90,90,90));setPixel(SCREEN_W-1,y,rgba(90,90,90));}
}

// ==========================================================================
//  FUEL (YELLOW balls)
// ==========================================================================
#define MAX_FUEL 150
#define FUEL_RADIUS 5.0f
#define FUEL_FRICTION 0.92f

#define FUEL_GROUND   0
#define FUEL_AIRBORNE 1
#define FUEL_EXITING  2

struct Fuel{
    float x,y,vx,vy;
    bool active;
    int state;
    float flightT,totalFlightT;
    int targetHub;
    int exitTimer;
};
Fuel fuels[MAX_FUEL];

uint32_t rng=12345;
uint32_t qrand(){rng^=rng<<13;rng^=rng>>17;rng^=rng<<5;return rng;}
float qrandf(){return (float)(qrand()%10000)/10000.0f;}
float qrandRange(float lo,float hi){return lo+qrandf()*(hi-lo);}

void spawnFuelAt(int idx,float fx,float fy){
    fuels[idx].x=fx;fuels[idx].y=fy;
    fuels[idx].vx=0;fuels[idx].vy=0;
    fuels[idx].active=true;fuels[idx].state=FUEL_GROUND;
    fuels[idx].flightT=0;fuels[idx].totalFlightT=0;
    fuels[idx].targetHub=0;fuels[idx].exitTimer=0;
}

void initFuels(){
    for(int i=0;i<MAX_FUEL;i++)fuels[i].active=false;
    float cx=(float)(SCREEN_W/2),cy=(float)(SCREEN_H/2);
    for(int i=0;i<100;i++){
        for(int a=0;a<50;a++){
            float fx=cx-60+(float)(qrand()%120);
            float fy=cy-50+(float)(qrand()%100);
            if(!insideWall(fx,fy,FUEL_RADIUS+3)){spawnFuelAt(i,fx,fy);break;}
        }
        if(!fuels[i].active) spawnFuelAt(i,cx+(float)((int)(qrand()%40)-20),cy+(float)((int)(qrand()%40)-20));
    }
}

void drawFuelBall(float fx,float fy,float radiusScale){
    float outerR=4.5f*radiusScale;
    float innerR=2.5f*radiusScale;
    if(outerR<0.5f)outerR=0.5f;
    if(innerR<0.3f)innerR=0.3f;
    fillCircleAA((int)fx,(int)fy,outerR,rgba(220,200,20));
    if(innerR>0.8f) fillCircleAA((int)fx,(int)fy,innerR,rgba(255,240,60));
}

// ==========================================================================
//  FRC Bot
// ==========================================================================
#define BOT_MAX_HELD 50
#define SHOT_COOLDOWN_FRAMES 3

struct Bot{
    float x,y,vx,vy,heading,vHeading;
    int halfW,halfH;
    bool intakeDown;
    int heldFuel;
    float intakeExtend;
    bool shooting;
    int shotCooldown;
};
Bot bot;

void initBot(){
    bot.x=60;bot.y=SCREEN_H/2;bot.vx=0;bot.vy=0;
    bot.heading=90;bot.vHeading=0;
    bot.halfW=10;bot.halfH=10;
    bot.intakeDown=false;bot.heldFuel=0;
    bot.intakeExtend=0;
    bot.shooting=false;bot.shotCooldown=0;
}

void drawBot(){
    int cx=(int)bot.x,cy=(int)bot.y;
    float ang=bot.heading,rad=ang*DEG2RAD;
    float co=cosf(rad),si=sinf(rad);

    int bHW=bot.halfW+3, bHH=bot.halfH+3;
    fillRotatedRect(cx,cy,bHW,bHH,ang,rgba(30,50,160));
    drawRotatedRectOutline(cx,cy,bHW+1,bHH+1,ang,2,rgba(60,80,200));
    fillRotatedRect(cx,cy,bot.halfW,bot.halfH,ang,rgba(35,35,45));

    float mOff=7.0f;
    for(int my=-1;my<=1;my+=2)for(int mx=-1;mx<=1;mx+=2){
        float lx_=mx*mOff,ly_=my*mOff;
        int sx=cx+(int)(co*lx_-si*ly_),sy=cy+(int)(si*lx_+co*ly_);
        fillRotatedRect(sx,sy,2,3,ang,rgba(60,60,70));
    }

    {
        float lx_=0,ly_=5;
        int bx=cx+(int)(co*lx_-si*ly_),by=cy+(int)(si*lx_+co*ly_);
        fillRotatedRect(bx,by,4,2,ang,rgba(80,20,20));
    }

    {
        float extDist=(float)(bHH-1)+bot.intakeExtend*6.0f;
        int fx=cx+(int)(si*extDist);
        int fy=cy+(int)(-co*extDist);
        int stripeHW=bHW-1;
        if(bot.intakeDown)
            fillRotatedRect(fx,fy,stripeHW,2,ang,rgba(180,255,180));
        else
            fillRotatedRect(fx,fy,stripeHW,1,ang,rgba(220,220,240));
    }

    fillRotatedRect(cx,cy,5,2,ang,rgba(200,200,200));
}

// ==========================================================================
//  Shooting
// ==========================================================================

void shootBall(){
    if(bot.heldFuel<=0)return;
    int slot=-1;
    for(int i=0;i<MAX_FUEL;i++)if(!fuels[i].active){slot=i;break;}
    if(slot<0)return;

    bot.heldFuel--;

    float rad=bot.heading*DEG2RAD;
    float co=cosf(rad),si=sinf(rad);

    // Back direction (opposite of front)
    float backX=-si,backY=co;
    // Lateral direction
    float latX=co,latY=si;

    // Pick random lane: left(-6), mid(0), right(+6)
    int lane=(int)(qrand()%3);
    float lateralOff=(lane==0)?-6.0f:(lane==2)?6.0f:0.0f;

    float spawnDist=(float)(bot.halfH+5);
    float sx=bot.x+backX*spawnDist+latX*lateralOff;
    float sy=bot.y+backY*spawnDist+latY*lateralOff;

    // Dumb shot: fires backward with fixed speed + small random scatter
    float shotSpeed=qrandRange(5.0f,7.0f);
    float shotAngle=qrandRange(-0.15f,0.15f); // small random angle offset (radians)
    float dirX=backX*cosf(shotAngle)-backY*sinf(shotAngle);
    float dirY=backX*sinf(shotAngle)+backY*cosf(shotAngle);

    // Flight time based on randomized distance
    float flightDist=qrandRange(80.0f,140.0f);
    float baseFlightT=flightDist/shotSpeed;
    if(baseFlightT<8)baseFlightT=8;
    if(baseFlightT>35)baseFlightT=35;

    fuels[slot].active=true;
    fuels[slot].state=FUEL_AIRBORNE;
    fuels[slot].x=sx;fuels[slot].y=sy;
    fuels[slot].vx=dirX*shotSpeed;
    fuels[slot].vy=dirY*shotSpeed;
    fuels[slot].flightT=0;fuels[slot].totalFlightT=baseFlightT;
    fuels[slot].targetHub=0; // unused now
    fuels[slot].exitTimer=0;
}

void landBall(int idx){
    Fuel&f=fuels[idx];

    // Off-screen? Just disappear
    if(f.x<-10||f.x>SCREEN_W+10||f.y<-10||f.y>SCREEN_H+10){
        f.active=false;
        return;
    }

    // Check both hubs passively
    float hubXs[2]={(float)BLUE_HUB_X,(float)RED_HUB_X};
    float hubYs[2]={(float)BLUE_HUB_Y,(float)RED_HUB_Y};
    for(int h=0;h<2;h++){
        float dx=f.x-hubXs[h],dy=f.y-hubYs[h];
        float dist=sqrtf(dx*dx+dy*dy);
        if(dist<HUB_GOAL_R){
            // Scored!
            f.state=FUEL_EXITING;
            f.exitTimer=15+(int)(qrand()%10);
            f.vx=0;f.vy=0;
            f.x=hubXs[h];f.y=hubYs[h];
            f.targetHub=h;
            return;
        } else if(dist<HUB_RIM_R){
            // Rim bounce
            f.state=FUEL_GROUND;
            if(dist>0.1f){
                float nx=dx/dist,ny=dy/dist;
                float bounceSpd=qrandRange(1.5f,3.5f);
                f.vx=nx*bounceSpd;f.vy=ny*bounceSpd;
                f.x=hubXs[h]+nx*(HUB_ZONE_HW+FUEL_RADIUS+2);
                f.y=hubYs[h]+ny*(HUB_ZONE_HH+FUEL_RADIUS+2);
            }
            return;
        }
    }

    // Didn't hit any hub — become a ground ball with residual velocity
    f.state=FUEL_GROUND;
    f.vx*=0.3f;f.vy*=0.3f;
}

// ==========================================================================
//  Bot face detection
// ==========================================================================
enum BotFace{FACE_FRONT,FACE_BACK,FACE_LEFT,FACE_RIGHT};
BotFace getFuelFace(float bx,float by,float head,int hw,int hh,float fx,float fy){
    float rad=head*DEG2RAD,co=cosf(rad),si=sinf(rad);
    float dx=fx-bx,dy=fy-by;
    float lx_=dx*co+dy*si,ly_=-dx*si+dy*co;
    float nx=fabs_(lx_)/(float)hw,ny=fabs_(ly_)/(float)hh;
    if(ny>=nx)return(ly_<0)?FACE_FRONT:FACE_BACK;
    else return(lx_<0)?FACE_LEFT:FACE_RIGHT;
}
float distSq(float ax,float ay,float bx,float by){float dx=ax-bx,dy=ay-by;return dx*dx+dy*dy;}

int score=0;

// ==========================================================================
//  Main
// ==========================================================================
int main(){
    uint32_t bgColor=rgba(25,25,35);
    rng=(uint32_t)Brain.Timer.time(msec)^0xDEADBEEF;
    initWalls();initFuels();initBot();

    #define TARGET_FPS 30
    #define TARGET_FRAME_MS (1000/TARGET_FPS)
    uint32_t frameStart=Brain.Timer.time(msec);int gf=0;

    #define DEADZONE 10
    #define MOVE_ACCEL 0.88f
    #define MOVE_MAX_SPEED 5.0f
    #define MOVE_FRICTION 0.5f
    #define ROT_ACCEL 0.88f
    #define ROT_MAX_SPEED 6.0f
    #define ROT_FRICTION 0.5f

    float interactR=18+FUEL_RADIUS,interactR2=interactR*interactR;
    float botRadius=sqrtf((float)(bot.halfW*bot.halfW+bot.halfH*bot.halfH))+3;

    while(true){
        int lx=Controller1.Axis4.position();
        int ly=Controller1.Axis3.position();
        int rx=Controller1.Axis1.position();
        if(lx>-DEADZONE&&lx<DEADZONE)lx=0;
        if(ly>-DEADZONE&&ly<DEADZONE)ly=0;
        if(rx>-DEADZONE&&rx<DEADZONE)rx=0;
        float jx=(float)lx/100,jy=(float)ly/100,jr=(float)rx/100;

        bot.intakeDown=Controller1.ButtonL1.pressing()||Controller1.ButtonL2.pressing();
        bot.shooting=Controller1.ButtonR1.pressing()||Controller1.ButtonR2.pressing();

        if(bot.intakeDown){
            if(bot.intakeExtend<1.0f)bot.intakeExtend+=0.15f;
            if(bot.intakeExtend>1.0f)bot.intakeExtend=1.0f;
        } else {
            if(bot.intakeExtend>0.0f)bot.intakeExtend-=0.15f;
            if(bot.intakeExtend<0.0f)bot.intakeExtend=0.0f;
        }

        // Shooting
        if(bot.shotCooldown>0)bot.shotCooldown--;
        if(bot.shooting&&bot.heldFuel>0&&bot.shotCooldown<=0){
            shootBall();
            bot.shotCooldown=SHOT_COOLDOWN_FRAMES;
        }

        // Rotation
        bot.vHeading+=jr*ROT_ACCEL;
        if(bot.vHeading>ROT_MAX_SPEED)bot.vHeading=ROT_MAX_SPEED;
        if(bot.vHeading<-ROT_MAX_SPEED)bot.vHeading=-ROT_MAX_SPEED;
        if(rx==0)bot.vHeading*=ROT_FRICTION;
        if(fabs_(bot.vHeading)<.05f&&rx==0)bot.vHeading=0;
        bot.heading+=bot.vHeading;
        while(bot.heading>=360)bot.heading-=360;while(bot.heading<0)bot.heading+=360;

        // Translation
        float hrad=bot.heading*DEG2RAD;
        float fwX=sinf(hrad),fwY=-cosf(hrad),stX=cosf(hrad),stY=sinf(hrad);
        bot.vx+=(jy*fwX+jx*stX)*MOVE_ACCEL;
        bot.vy+=(jy*fwY+jx*stY)*MOVE_ACCEL;
        float spd=sqrtf(bot.vx*bot.vx+bot.vy*bot.vy);
        if(spd>MOVE_MAX_SPEED){bot.vx=bot.vx/spd*MOVE_MAX_SPEED;bot.vy=bot.vy/spd*MOVE_MAX_SPEED;}
        if(lx==0&&ly==0){bot.vx*=MOVE_FRICTION;bot.vy*=MOVE_FRICTION;
            if(fabs_(bot.vx)<.05f)bot.vx=0;if(fabs_(bot.vy)<.05f)bot.vy=0;}
        bot.x+=bot.vx;bot.y+=bot.vy;

        int bE=bot.halfW+4;
        if(bot.x<bE){bot.x=bE;bot.vx*=-.3f;}
        if(bot.x>SCREEN_W-bE){bot.x=SCREEN_W-bE;bot.vx*=-.3f;}
        if(bot.y<bE){bot.y=bE;bot.vy*=-.3f;}
        if(bot.y>SCREEN_H-bE){bot.y=SCREEN_H-bE;bot.vy*=-.3f;}

        resolveCircleWalls(bot.x,bot.y,botRadius,bot.vx,bot.vy,0.2f);

        // Fuel physics
        for(int i=0;i<MAX_FUEL;i++){
            if(!fuels[i].active)continue;

            if(fuels[i].state==FUEL_AIRBORNE){
                fuels[i].x+=fuels[i].vx;
                fuels[i].y+=fuels[i].vy;
                fuels[i].flightT+=1.0f;
                // Off-screen mid-flight? Gone
                if(fuels[i].x<-20||fuels[i].x>SCREEN_W+20||fuels[i].y<-20||fuels[i].y>SCREEN_H+20){
                    fuels[i].active=false;continue;
                }
                if(fuels[i].flightT>=fuels[i].totalFlightT) landBall(i);
                continue;
            }

            if(fuels[i].state==FUEL_EXITING){
                fuels[i].exitTimer--;
                if(fuels[i].exitTimer<=0){
                    score++;
                    fuels[i].state=FUEL_GROUND;
                    if(fuels[i].targetHub==0){
                        fuels[i].x=(float)(BLUE_HUB_X-HUB_ZONE_HW-FUEL_RADIUS-4);
                        fuels[i].y=(float)BLUE_HUB_Y+qrandRange(-8.0f,8.0f);
                        fuels[i].vx=-EXIT_SPEED;
                        fuels[i].vy=qrandRange(-0.5f,0.5f);
                    } else {
                        fuels[i].x=(float)(RED_HUB_X+HUB_ZONE_HW+FUEL_RADIUS+4);
                        fuels[i].y=(float)RED_HUB_Y+qrandRange(-8.0f,8.0f);
                        fuels[i].vx=EXIT_SPEED;
                        fuels[i].vy=qrandRange(-0.5f,0.5f);
                    }
                }
                continue;
            }

            // Ground physics
            fuels[i].x+=fuels[i].vx;fuels[i].y+=fuels[i].vy;
            fuels[i].vx*=FUEL_FRICTION;fuels[i].vy*=FUEL_FRICTION;
            if(fabs_(fuels[i].vx)<.02f)fuels[i].vx=0;if(fabs_(fuels[i].vy)<.02f)fuels[i].vy=0;
            if(fuels[i].x<FUEL_RADIUS){fuels[i].x=FUEL_RADIUS;fuels[i].vx*=-.5f;}
            if(fuels[i].x>SCREEN_W-FUEL_RADIUS){fuels[i].x=SCREEN_W-FUEL_RADIUS;fuels[i].vx*=-.5f;}
            if(fuels[i].y<FUEL_RADIUS){fuels[i].y=FUEL_RADIUS;fuels[i].vy*=-.5f;}
            if(fuels[i].y>SCREEN_H-FUEL_RADIUS){fuels[i].y=SCREEN_H-FUEL_RADIUS;fuels[i].vy*=-.5f;}
            resolveCircleWalls(fuels[i].x,fuels[i].y,FUEL_RADIUS,fuels[i].vx,fuels[i].vy,0.4f);

            for(int j=i+1;j<MAX_FUEL;j++){
                if(!fuels[j].active||fuels[j].state!=FUEL_GROUND)continue;
                float dx=fuels[j].x-fuels[i].x,dy=fuels[j].y-fuels[i].y;
                float dist=sqrtf(dx*dx+dy*dy),minD=FUEL_RADIUS*2;
                if(dist<minD&&dist>.01f){float nx=dx/dist,ny=dy/dist,pen=(minD-dist)*.5f;
                    fuels[i].x-=nx*pen;fuels[i].y-=ny*pen;fuels[j].x+=nx*pen;fuels[j].y+=ny*pen;
                    float vi=fuels[i].vx*nx+fuels[i].vy*ny,vj=fuels[j].vx*nx+fuels[j].vy*ny;
                    fuels[i].vx+=(vj-vi)*nx*.8f;fuels[i].vy+=(vj-vi)*ny*.8f;
                    fuels[j].vx+=(vi-vj)*nx*.8f;fuels[j].vy+=(vi-vj)*ny*.8f;}
            }
        }

        // Bot vs ground fuel
        for(int i=0;i<MAX_FUEL;i++){
            if(!fuels[i].active||fuels[i].state!=FUEL_GROUND)continue;
            float d2=distSq(bot.x,bot.y,fuels[i].x,fuels[i].y);
            if(d2<interactR2){
                BotFace face=getFuelFace(bot.x,bot.y,bot.heading,bot.halfW+3,bot.halfH+3,fuels[i].x,fuels[i].y);
                // Only collect if intake is down AND not full
                if(face==FACE_FRONT&&bot.intakeDown&&bot.heldFuel<BOT_MAX_HELD){
                    fuels[i].active=false;bot.heldFuel++;
                }else{
                    // Push ball away (including when intake is full)
                    float dist=sqrtf(d2);if(dist>.01f){
                        float nx=(fuels[i].x-bot.x)/dist,ny=(fuels[i].y-bot.y)/dist;
                        float ps=sqrtf(bot.vx*bot.vx+bot.vy*bot.vy)*.7f+.3f;
                        fuels[i].vx+=nx*ps;fuels[i].vy+=ny*ps;
                        float pen=interactR-dist;if(pen>0){fuels[i].x+=nx*pen;fuels[i].y+=ny*pen;}}
                }
            }
        }

        // --- Draw ---
        clearBuffer(bgColor);
        drawField();

        // Ground balls
        for(int i=0;i<MAX_FUEL;i++){
            if(!fuels[i].active||fuels[i].state!=FUEL_GROUND)continue;
            drawFuelBall(fuels[i].x,fuels[i].y,1.0f);
        }

        drawBot();

        // Airborne balls (drawn on top — they're in the air)
        for(int i=0;i<MAX_FUEL;i++){
            if(!fuels[i].active||fuels[i].state!=FUEL_AIRBORNE)continue;
            float t=fuels[i].flightT/fuels[i].totalFlightT;
            // Parabola: shrinks to 0.4 at midpoint, full size at start/end
            float scale=1.0f-0.6f*sinf(PI*t);
            if(scale<0.3f)scale=0.3f;
            drawFuelBall(fuels[i].x,fuels[i].y,scale);
        }

        drawStylizedScore(score,gf);
        drawHeldHUD(bot.heldFuel);

        // Intake HUD
        if(bot.intakeDown){
            fillRect(SCREEN_W-50,4,SCREEN_W-6,16,rgba(40,120,40));
            for(int y_=6;y_<=14;y_++)setPixel(SCREEN_W-46,y_,rgba(200,255,200));
            for(int y_=6;y_<=14;y_++){setPixel(SCREEN_W-42,y_,rgba(200,255,200));setPixel(SCREEN_W-36,y_,rgba(200,255,200));}
            setPixel(SCREEN_W-41,7,rgba(200,255,200));setPixel(SCREEN_W-40,8,rgba(200,255,200));
            setPixel(SCREEN_W-39,9,rgba(200,255,200));setPixel(SCREEN_W-38,10,rgba(200,255,200));
            setPixel(SCREEN_W-37,11,rgba(200,255,200));
        }

        // Shooting indicator
        if(bot.shooting&&bot.heldFuel>0){
            fillRect(SCREEN_W-50,20,SCREEN_W-6,32,rgba(120,40,40));
        }

        Brain.Screen.drawImageFromBuffer(screenBuffer,0,0,SCREEN_W,SCREEN_H);
        Brain.Screen.render();

        gf++;uint32_t elapsed=Brain.Timer.time(msec)-frameStart;
        if(elapsed<TARGET_FRAME_MS)wait(TARGET_FRAME_MS-elapsed,msec);
        frameStart+=TARGET_FRAME_MS;
    }
    return 0;
}