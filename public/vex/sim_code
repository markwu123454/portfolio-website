struct WallCircle{float x,y,r;};
struct WallLine{float x1,y1,x2,y2,thickness;};
struct WallRect{float cx,cy,hw,hh;};
#define MAX_WC 16
#define MAX_WL 32
#define MAX_WR 24
WallCircle wcs[MAX_WC];int nwc=0;
WallLine wls[MAX_WL];int nwl=0;
WallRect wrs[MAX_WR];int nwr=0;
void addWC(float x,float y,float r){if(nwc<MAX_WC)wcs[nwc++]={x,y,r};}
void addWL(float x1,float y1,float x2,float y2,float t){if(nwl<MAX_WL)wls[nwl++]={x1,y1,x2,y2,t};}
void addWR(float cx,float cy,float hw,float hh){if(nwr<MAX_WR)wrs[nwr++]={cx,cy,hw,hh};}

void closestPtSeg(float px,float py,float ax,float ay,float bx,float by,float&cx,float&cy){
    float dx=bx-ax,dy=by-ay,l2=dx*dx+dy*dy;
    if(l2<.001f){cx=ax;cy=ay;return;}
    float t=fclamp(((px-ax)*dx+(py-ay)*dy)/l2,0,1);cx=ax+t*dx;cy=ay+t*dy;
}

void resolveCircleRect(float&px,float&py,float rad,float&vx,float&vy,float bounce,
                       float rcx,float rcy,float rhw,float rhh){
    float cpx=fclamp(px,rcx-rhw,rcx+rhw);
    float cpy=fclamp(py,rcy-rhh,rcy+rhh);
    float dx=px-cpx,dy=py-cpy;
    float dist=sqrtf(dx*dx+dy*dy);
    if(dist<rad&&dist>0.01f){
        float nx=dx/dist,ny=dy/dist;
        px+=nx*(rad-dist);py+=ny*(rad-dist);
        float vn=vx*nx+vy*ny;
        if(vn<0){vx-=(1+bounce)*vn*nx;vy-=(1+bounce)*vn*ny;}
    } else if(dist<0.01f){
        float dxL=px-(rcx-rhw), dxR=(rcx+rhw)-px;
        float dyT=py-(rcy-rhh), dyB=(rcy+rhh)-py;
        float minD=dxL; int axis=0;
        if(dxR<minD){minD=dxR;axis=1;}
        if(dyT<minD){minD=dyT;axis=2;}
        if(dyB<minD){minD=dyB;axis=3;}
        switch(axis){
            case 0: px=rcx-rhw-rad; if(vx>0)vx*=-bounce; break;
            case 1: px=rcx+rhw+rad; if(vx<0)vx*=-bounce; break;
            case 2: py=rcy-rhh-rad; if(vy>0)vy*=-bounce; break;
            case 3: py=rcy+rhh+rad; if(vy<0)vy*=-bounce; break;
        }
    }
}

void resolveCircleWalls(float&px,float&py,float rad,float&vx,float&vy,float bounce){
    for(int i=0;i<nwc;i++){
        float dx=px-wcs[i].x,dy=py-wcs[i].y,dist=sqrtf(dx*dx+dy*dy),md=rad+wcs[i].r;
        if(dist<md&&dist>.01f){float nx=dx/dist,ny=dy/dist;px+=nx*(md-dist);py+=ny*(md-dist);
            float vn=vx*nx+vy*ny;if(vn<0){vx-=(1+bounce)*vn*nx;vy-=(1+bounce)*vn*ny;}}
    }
    for(int i=0;i<nwl;i++){
        float cx,cy;closestPtSeg(px,py,wls[i].x1,wls[i].y1,wls[i].x2,wls[i].y2,cx,cy);
        float dx=px-cx,dy=py-cy,dist=sqrtf(dx*dx+dy*dy),md=rad+wls[i].thickness;
        if(dist<md&&dist>.01f){float nx=dx/dist,ny=dy/dist;px+=nx*(md-dist);py+=ny*(md-dist);
            float vn=vx*nx+vy*ny;if(vn<0){vx-=(1+bounce)*vn*nx;vy-=(1+bounce)*vn*ny;}}
    }
    for(int i=0;i<nwr;i++){
        resolveCircleRect(px,py,rad,vx,vy,bounce,wrs[i].cx,wrs[i].cy,wrs[i].hw,wrs[i].hh);
    }
}

bool insideWall(float px,float py,float cl){
    for(int i=0;i<nwc;i++){float dx=px-wcs[i].x,dy=py-wcs[i].y;if(sqrtf(dx*dx+dy*dy)<wcs[i].r+cl)return true;}
    for(int i=0;i<nwl;i++){
        float cx,cy;closestPtSeg(px,py,wls[i].x1,wls[i].y1,wls[i].x2,wls[i].y2,cx,cy);
        float dx=px-cx,dy=py-cy;if(sqrtf(dx*dx+dy*dy)<wls[i].thickness+cl)return true;}
    for(int i=0;i<nwr;i++){
        float cpx=fclamp(px,wrs[i].cx-wrs[i].hw,wrs[i].cx+wrs[i].hw);
        float cpy=fclamp(py,wrs[i].cy-wrs[i].hh,wrs[i].cy+wrs[i].hh);
        float dx=px-cpx,dy=py-cpy;if(sqrtf(dx*dx+dy*dy)<cl)return true;
    }
    return false;
}

